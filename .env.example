# Copy to .env and adjust. Values here mirror the built-in config defaults;
# anything you leave out falls back to the default baked into config.yml.

# Listeners
PUBLIC_PORT=8080
ADMIN_PORT=9090

# Observability
LOG_LEVEL=info
METRICS_ENABLED=false

# Defaults
REQUEST_TIMEOUT=30s
UPSTREAM_RESPONSE_HEADER_TIMEOUT=30s
BODY_LIMIT=1MB
SHUTDOWN_TIMEOUT=5s

# Rate limiting
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_RATE_PER_SEC=5
RATE_LIMIT_KEY_PREFIX=rl

# Redis
# Local run (go run / make run): localhost:6379
# Full docker compose (app in the compose network): redis:6379
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Host port the compose Redis service is published on (compose only)
REDIS_EXTERNAL_PORT=6379
